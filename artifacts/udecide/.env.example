# UDecide Environment Variables
# Copy this file to .env and fill in your API keys

# LegiScan API - for state legislation tracking
# Get your key at: https://legiscan.com/legiscan
LEGISCAN_API_KEY=

# Congress.gov API - for federal legislation and member data
# Get your key at: https://api.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=

# Google Gemini AI - for the Fact Checker feature
# NOTE: The Gemini key is NO LONGER read by the app. The Fact Checker now calls
# the API Server's /fact-check proxy, and the key lives on the server as
# GEMINI_API_KEY (see artifacts/api-server/.env.example) so it is never bundled
# into the shipped app.

# Note: When API keys are missing, the app uses built-in mock data
# and shows a developer warning. All features remain usable.
