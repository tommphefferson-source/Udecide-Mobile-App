# API Server configuration
# Copy values into Replit Secrets (do not commit real secrets).

# Application identity
APP_NAME="UDecide Civic API"

# Runtime environment: development | production
NODE_ENV=development

# Network binding. PORT is injected by the Replit workflow; HOST defaults to 0.0.0.0.
HOST=0.0.0.0
PORT=8080

# Google Civic Information API key (elections + voter-info endpoints).
# GOOGLE_CIVIC_API_KEY is preferred; the server falls back to CIVIC_API_KEY.
GOOGLE_CIVIC_API_KEY=

# Cicero API key (representatives endpoint — server-side only, never EXPO_PUBLIC_*).
CICERO_API_KEY=

# Google Gemini API key (Fact Checker — server-side only, never EXPO_PUBLIC_*).
# When unset, /api/fact-check returns canned demo responses so the feature works.
GEMINI_API_KEY=

# Optional: override the Gemini model id (defaults to gemini-3.5-flash).
GEMINI_MODEL=

# Optional: Fact Checker rate limit — max requests per user (AUTHTOKEN, else IP)
# per sliding window. Defaults: 10 requests / 15 minutes.
FACT_CHECK_LIMIT=
FACT_CHECK_WINDOW_MINUTES=
